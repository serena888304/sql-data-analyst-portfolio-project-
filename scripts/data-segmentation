/*
===============================================================================
Data Segmentation Analysis
===============================================================================
Purpose:
    - To group data into meaningful categories for targeted insights.
    - For customer segmentation, product categorization, or regional analysis.

SQL Functions Used:
    - CASE: Defines custom segmentation logic.
    - GROUP BY: Groups data into segments.
===============================================================================
*/

/* Segment products into cost ranges and
count how many products fall into each segments*/

WITH product_segments AS(
SELECT
	p.product_key,
	p.product_name,
	p.cost,
    CASE 
		WHEN p.cost < 100 THEN 'Below 100'
		WHEN p.cost BETWEEN 100 AND 500 THEN '100-500'
        WHEN p.cost BETWEEN 500 AND 1000 THEN '500-1000'
        ELSE 'Above 1000'
	END cost_range,
    f.sales_amount
FROM DataWarehouseAnalytics.dim_products p
LEFT JOIN fact_sales f ON p. product_key = f.product_key)

SELECT
	cost_range,
    COUNT(DISTINCT product_key) AS total_products,
    SUM(sales_amount) AS total_revenue
FROM product_segments
GROUP BY cost_range
ORDER BY total_products DESC;

/* Group customers into three segments based on their spendidng behaviour:
-VIP: Customer with at least 12 months of history and spending more than 5000
-Regular: Customers with at least 12 months of history but spending 5000 or less
-New: Customers with a lifespan less than 12 months
And find the total number of the customer by each group
*/

-- step1: create lifespan & total spending
WITH customer_spending AS(
SELECT 
c.customer_key,
SUM(f.sales_amount) as total_spending,
MIN(order_date) as first_order,
MAX(order_date) as last_order,
timestampdiff(month, MIN(order_date), MAX(order_date)) as lifespan
FROM DataWarehouseAnalytics.fact_sales f
LEFT JOIN dim_customers c 
ON c.customer_key = f.customer_key
GROUP BY c.customer_key)

-- step3: 
SELECT 
	customer_segment,
	COUNT(customer_key) as total_customers
FROM 
(
-- step2: create customer segment
	SELECT
		customer_key,
		CASE 
			WHEN lifespan >= 12 AND total_spending >5000 THEN 'VIP'
			WHEN lifespan >=12 AND total_spending <5000 THEN 'Regular'
			ELSE 'New'
		END customer_segment
	FROM customer_spending
)t
GROUP BY customer_segment
ORDER BY total_customers DESC;

